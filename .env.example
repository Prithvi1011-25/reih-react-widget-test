# 1. Copy this file to `.env` in the project root:
#    cp .env.example .env
#
# 2. Replace the placeholder below with your ReimagineHome public key.
#    The key is passed to the widget via data-public-key on the script tag
#    (see src/pages/ScriptEmbedPage.tsx). Do NOT commit `.env`.

VITE_REIH_PUBLIC_KEY=your_public_key_here

# Optional: override the default production widget script URL
# VITE_REIH_WIDGET_SCRIPT_URL=https://widget.styldod.com/widget.js

# Optional: widget UI language (default en-US)
# VITE_REIH_WIDGET_LANGUAGE=en-US

# Local dev only: public URL where your demo images are hosted (deploy or ngrok).
# Required when testing the widget on localhost — the API cannot fetch local images.
# VITE_PUBLIC_ASSET_ORIGIN=https://your-demo.vercel.app
